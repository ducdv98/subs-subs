{
  "manifest_version": 3,
  "name": "Dual Subtitles for YouTube",
  "version": "0.1.0",
  "description": "Shows YouTube's native captions plus a translated second line for language learning.",
  "permissions": ["storage"],
  "host_permissions": ["https://www.youtube.com/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {},
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["content/index.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["lib/settings.js", "lib/subtitle-engine.js", "content/player.js", "content/vtt.js"],
      "matches": ["https://www.youtube.com/*"]
    }
  ]
}
